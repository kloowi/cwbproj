PORT=5050
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Microsoft Agent Framework sidecar (careerhive/agent-service)
# Leave unset to run the in-process staged pipeline; set to enable the sidecar.
AGENT_SERVICE_URL=http://localhost:7070
AGENT_SERVICE_TIMEOUT_MS=60000

# Cosmos DB
COSMOS_CONNECTION_STRING=
COSMOS_DB_NAME=jobpilot
COSMOS_CONTAINER_NAME=analyses
