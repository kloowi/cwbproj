{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["backend/**/*.js", "frontend/src/**/*"],
  "exclude": ["**/node_modules", "**/dist", "**/build"]
}
